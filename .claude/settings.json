{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Bash(npm run build *)",
      "Read(~/.zshrc)"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(/.env)",
      "Read(/.env.*)",
      "Read(/**/*.keystore)",
      "Read(/**/credentials.json)",
      "Read(/**/*.mobileprovision)",
      "Read(/**/*.p12)",
      "Read(/**/android/keystores/*)",
      "Read(/**/ios/certs/*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "allowedMcpServers": [{ "serverName": "figma-desktop" }]
}
