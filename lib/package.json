{
  "name": "marys-ui",
  "version": "1.0.0",
  "description": "Marys UI system package",
  "license": "ISC",
  "author": "",
  "keywords": [
    "react-native",
    "ui",
    "healthcare",
    "design-system"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "plugin": "./dist/plugin.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "watch": "tsc --watch",
    "dev": "npm run storybook:rn & npm run storybook:web",
    "dev:ios": "npm run storybook:rn-ios & npm run storybook:web",
    "dev:android": "npm run storybook:rn-android & npm run storybook:web",
    "build": "tsc",
    "postbuild": "rm -rf dist/fonts && mkdir dist/fonts && cp -r icons/*.svg dist/icons/ && cp -r fonts/*.ttf dist/fonts/",
    "test": "jest && vitest run",
    "storybook": "storybook dev",
    "storybook:web": "npm run storybook -- --config-dir storybook/.storybook",
    "storybook:rn": "cd storybook && expo start",
    "storybook:rn-ios": "cd storybook && expo start --ios",
    "storybook:rn-android": "cd storybook && expo start --android",
    "tokens:sync": "node scripts/sync-figma-tokens.ts"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-font": "^14.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-transform-class-static-block": "^7.27.1",
    "@babel/preset-env": "^7.29.0",
    "@chromatic-com/storybook": "^4.0.0",
    "@eslint/js": "^9.39.3",
    "@expo/metro-runtime": "~6.1.2",
    "@jest/globals": "^30.2.0",
    "@newhighsco/storybook-addon-svgr": "^4.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native/babel-preset": "^0.83.1",
    "@react-native/metro-babel-transformer": "^0.84.1",
    "@storybook/addon-a11y": "^10.2.8",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/addon-ondevice-actions": "^10.0.0",
    "@storybook/addon-ondevice-backgrounds": "^10.0.0",
    "@storybook/addon-ondevice-controls": "^10.0.0",
    "@storybook/addon-ondevice-notes": "^10.0.0",
    "@storybook/addon-vitest": "^10.2.8",
    "@storybook/react": "^10.0.0",
    "@storybook/react-native": "^10.0.0",
    "@storybook/react-native-web-vite": "^10.0.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "babel-jest": "^30.2.0",
    "babel-preset-expo": "^54.0.10",
    "cross-env": "^10.0.0",
    "eslint": "^9.39.3",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "expo": "^54.0.20",
    "expo-constants": "~18.0.10",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.13",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "globals": "^14.0.0",
    "jest": "^30.2.0",
    "prettier": "3.8.1",
    "react": "19.1.0",
    "react-native-worklets": "0.5.1",
    "react-strict-dom": "^0.0.55",
    "react-test-renderer": "19.1.0",
    "storybook": "^10.2.16",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.1.12",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.0.18"
  },
  "sideEffects": false,
  "peerDependencies": {
    "expo-font": "^14.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-web": "~0.21.0",
    "react-native-svg": "15.12.1"
  },
  "peerDependenciesMeta": {
    "react-native-gesture-handler": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    },
    "react-native-web": {
      "optional": true
    }
  }
}
