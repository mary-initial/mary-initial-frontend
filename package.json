{
  "name": "marys-ui",
  "version": "1.0.0",
  "description": "Marys UI system package",
  "license": "ISC",
  "author": "",
  "keywords": [
    "react-native",
    "ui",
    "healthcare",
    "design-system",
    "components"
  ],
  "repository": {
    "type": "git",
    "url": "https://example.com/your-org/marys-ui.git"
  },
  "homepage": "https://example.com/your-org/marys-ui#readme",
  "bugs": {
    "url": "https://example.com/your-org/marys-ui/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "storybook",
    "tests/example"
  ],
  "scripts": {
    "dev": "tsc --p tsconfig.build.json --watch & npm run storybook",
    "build": "tsc --p tsconfig.build.json",
    "test": "jest && vitest run",
    "test-e2e": "maestro test --output ./test-results tests/e2e",
    "storybook": "npm run storybook --workspace=storybook",
    "storybook-test": "npm run storybook:web-no-open --workspace=storybook",
    "example": "npm run start --workspace=tests/example",
    "example:ios": "npm run ios --workspace=tests/example",
    "example:android": "npm android --workspace=tests/example",
    "watchman": "watchman watch-del './' ; watchman watch-project './'"
  },
  "dependencies": {
    "react": "19.2.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@jest/globals": "^30.2.0",
    "@react-native/babel-preset": "^0.83.1",
    "@storybook/addon-vitest": "^10.2.8",
    "@storybook/react": "^10.0.0",
    "@storybook/react-native-web-vite": "^10.0.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "19.1.10",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "react-test-renderer": "19.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.18"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-svg": ">=13.0.0",
    "react-native-web": ">=0.18.0"
  },
  "peerDependenciesMeta": {
    "react-native-gesture-handler": { "optional": true },
    "react-native-reanimated": { "optional": true },
    "react-native-svg": { "optional": true },
    "react-native-web": { "optional": true }
  }
}
